# ================================================
# PokéMarket Intelligence — Environment Variables
# ================================================
# Kopiere diese Datei nach .env.local und trage deine Werte ein

# --- PFLICHT: Pokémon TCG API ---
# Kostenlos registrieren: https://dev.pokemontcg.io/
POKEMON_TCG_API_KEY=your_key_here

# --- PFLICHT: Anthropic / Claude AI ---
# Holen bei: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# --- PFLICHT: Sicherheit ---
# Beliebigen langen zufälligen String generieren
CRON_SECRET=your_random_secret_here

# --- Newsletter: Beehiiv ---
# Kostenlos bis 2.500 Abonnenten: https://beehiiv.com/
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# --- Video: ElevenLabs Text-to-Speech ---
# Kostenfreies Kontingent: https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- Video: Remotion Lambda (optional) ---
REMOTION_LAMBDA_ENDPOINT=
REMOTION_API_KEY=

# --- Video: YouTube Upload ---
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- Social Media: Buffer ---
BUFFER_ACCESS_TOKEN=
BUFFER_INSTAGRAM_ID=
BUFFER_TWITTER_ID=
BUFFER_TIKTOK_ID=

# --- Affiliate URLs ---
NEXT_PUBLIC_CARDMARKET_URL=https://www.cardmarket.com/en/Pokemon
NEXT_PUBLIC_AMAZON_URL=https://www.amazon.de/s?k=pokemon+booster
NEXT_PUBLIC_TRADE_REPUBLIC_URL=
CARDMARKET_AFFILIATE_URL=https://www.cardmarket.com/en/Pokemon
TRADE_REPUBLIC_AFFILIATE_URL=

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=https://pokemarketintelligence.com
